diff --git a/src/video/x11/SDL_x11video.c b/src/video/x11/SDL_x11video.c
index c4f00021f..454d4060a 100644
--- a/src/video/x11/SDL_x11video.c
+++ b/src/video/x11/SDL_x11video.c
@@ -479,6 +479,53 @@ void X11_VideoQuit(SDL_VideoDevice *_this)
     X11_QuitPen(_this);
     X11_QuitClipboard(_this);
     X11_QuitXsettings(_this);
+
+    SDL_DisplayID *displays;
+    int i;
+
+    displays = SDL_GetDisplays(NULL);
+    if (displays) {
+        for (i = 0; displays[i]; ++i) {
+            SDL_DisplayID display_id = displays[i];
+
+            SDL_VideoDisplay *display = SDL_GetVideoDisplay(display_id);
+            SDL_DisplayMode **modes;
+            int num_modes;
+
+            // Force restore desktop mode, or we may not be able to delete a custom mode
+            // if it's the active one
+            X11_SetDisplayMode(_this, display, &display->desktop_mode);
+            modes = SDL_GetFullscreenDisplayModes(display_id, &num_modes);
+            if (modes) {
+                for (int m = 0; m < num_modes; ++m) {
+                    const SDL_DisplayMode *mode = modes[m];
+
+                    /* internal == NULL => injected custom mode */
+                    if (mode && mode->internal == NULL) {
+                        const SDL_CustomDisplayMode *custom =
+                            SDL_GetCustomDisplayMode(display_id, mode);
+
+                        if (custom && custom->backend_data) {
+                            X11_CustomModeData *x11mode = (X11_CustomModeData *)custom->backend_data;
+
+                                if (x11mode->mode_id != None) {
+                                    X11_XRRDeleteOutputMode(data->display, x11mode->output, x11mode->mode_id);
+                                    X11_XRRDestroyMode(data->display, x11mode->mode_id);
+                                }
+                            /* X11 backend owns this */
+                            SDL_free(custom->backend_data);
+printf("Purge du backend_data de %dx%d\n", mode->w, mode->h);
+                            /* prevent dangling pointer */
+                            ((SDL_CustomDisplayMode *)custom)->backend_data = NULL;
+                        }
+                    }
+                }
+                SDL_free(modes);
+            }
+        }
+        SDL_free(displays);
+    }
+
 }
 
