+typedef struct SDL_CustomModeEntry
+{
+    SDL_DisplayID display_id;
+    SDL_DisplayMode mode;         /* Copy returned to client */ // renommer en mode
+    SDL_CustomDisplayMode custom_mode;   /* Full modeline + backend_data */
+} SDL_CustomModeEntry;
+
+static int num_custom_modes = 0;
+#define MAX_CUSTOM_MODES 128 // Ugly, should be dynamic
+
+static SDL_CustomModeEntry SDL_CustomFullscreenModes[MAX_CUSTOM_MODES];
+
+SDL_CustomDisplayMode *SDL_GetCustomDisplayMode(SDL_DisplayID display_id,
+                         const SDL_DisplayMode *mode)
+{
+printf("Number of custom modes: %d\n", num_custom_modes);
+    for (int i = 0; i < num_custom_modes; ++i) {
+        SDL_CustomModeEntry *entry = &SDL_CustomFullscreenModes[i];
+printf("Entry: %d : %d -> %dx%d@%.2f - %dx%d@%.2f\n", display_id, entry->display_id, mode->w, mode->h, mode->refresh_rate, entry->mode.w, entry->mode.h, entry->mode.refresh_rate);
+        if (entry->display_id == display_id &&
+            entry->custom_mode.h == mode->h &&
+            entry->custom_mode.w == mode->w &&
+            entry->custom_mode.refresh_rate == mode->refresh_rate) {
+printf("Found a custom display mode!\n");
+            return &entry->custom_mode;
+        }
+    }
+printf("Could not find a matching custom display mode :(\n");
+    return NULL;
+}
+
+SDL_DisplayMode *SDL_AddCustomDisplayMode(SDL_DisplayID display, const SDL_CustomDisplayMode *mode)
+{
+    SDL_DisplayMode new_mode;
+
+    if (!mode || num_custom_modes >= MAX_CUSTOM_MODES) {
+        return NULL;
+    }
+
+    if (num_custom_modes >= MAX_CUSTOM_MODES) {
+        SDL_SetError("Max number of custom mode exceeded");
+        return NULL;
+    }
+
+    SDL_VideoDisplay *videodisplay = SDL_GetVideoDisplay(display);
+    if (!videodisplay) {
+        return NULL;
+    }
+
+    // Fill a temporary mode, validate it and then add in the custom list
+    new_mode.displayID = display;
+    new_mode.format = SDL_PIXELFORMAT_ARGB8888; // TODO: don't force this
+    new_mode.w = mode->w;
+    new_mode.h = mode->h;
+    new_mode.pixel_density = 1.0;
+    new_mode.refresh_rate = mode->refresh_rate;
+    new_mode.internal = NULL; /* This is how we'll differ a custom SDL_DisplayMode from a system SDL_DisplayMode */
+
+    // Copy from kmsdrm's CalculateRefreshRate
+    new_mode.refresh_rate_numerator = mode->pixel_clock_khz * 1000;
+    new_mode.refresh_rate_denominator = mode->htotal * mode->vtotal;
+
+    if (mode->flags & SDL_MODELINE_FLAG_INTERLACE) {
+        new_mode.refresh_rate_numerator *= 2;
+    }
+
+    if (mode->flags & SDL_MODELINE_FLAG_DBLSCAN) {
+        new_mode.refresh_rate_denominator *= 2;
+    }
+
+    /*if (mode->vscan > 1) {
+        new_mode.refresh_rate_denominator *= mode->vscan;
+    }*/
+
+    if(!SDL_AddFullscreenDisplayMode(videodisplay, &new_mode)) {
+        return NULL;
+    }
+
+    // At this point, SDL_AddFullscreenDisplayMode has validated the new mode, let's go on
+    // This part is heavily inspired from SDL_AddFullscreenDisplayMode
+    SDL_CustomModeEntry *entry = &SDL_CustomFullscreenModes[num_custom_modes++];
+    SDL_memset(entry, 0, sizeof(*entry));
+    SDL_memcpy(&entry->mode, &new_mode, sizeof(new_mode));
+    SDL_memcpy(&entry->custom_mode, mode, sizeof(SDL_CustomDisplayMode));
+    SDL_FinalizeDisplayMode(&entry->mode);
+    entry->display_id = display;
+    entry->custom_mode.backend_data = NULL;
+    /* Handling the list of custom modes could have been done like the list of modes in a display
+     * (see SDL_AddFullscreenDisplayMode how it was done there)
+       But it would have turned to a nightmare when the list size has to be increased because
+       we'd have to remap all the mode pointers in the SDL main modes list
+    */
+
+printf("-> Added new mode %dx%d@%.2f to display id %d and takes %ld bytes\n", entry->mode.w, entry->mode.h, entry->mode.refresh_rate, entry->mode.displayID, sizeof(SDL_CustomModeEntry));
+    return &entry->mode;
+}
