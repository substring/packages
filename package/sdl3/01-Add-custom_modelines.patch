+static drmModeModeInfo *KMSDRM_CreateModeFromCustom(const SDL_CustomDisplayMode *custom)
+{
+    if (!custom) {
+        return NULL;
+    }
+
+    drmModeModeInfo *mode = SDL_malloc(sizeof(drmModeModeInfo));
+    if (!mode) {
+        return NULL;
+    }
+
+    SDL_memset(mode, 0, sizeof(*mode));
+
+    SDL_strlcpy(mode->name, custom->name, SDL_min(DRM_DISPLAY_MODE_LEN, SDL_DISPLAY_MODE_LEN));
+    mode->hdisplay = custom->w;
+    mode->vdisplay = custom->h;
+    mode->hsync_start = custom->hsync_start;
+    mode->hsync_end   = custom->hsync_end;
+    mode->htotal      = custom->htotal;
+    mode->vsync_start = custom->vsync_start;
+    mode->vsync_end   = custom->vsync_end;
+    mode->vtotal      = custom->vtotal;
+    mode->clock = custom->pixel_clock_khz;
+    if (custom->flags & SDL_MODELINE_FLAG_PHSYNC) {
+        mode->flags |= DRM_MODE_FLAG_PHSYNC;
+    }
+    if (custom->flags & SDL_MODELINE_FLAG_NHSYNC) {
+        mode->flags |= DRM_MODE_FLAG_NHSYNC;
+    }
+    if (custom->flags & SDL_MODELINE_FLAG_PVSYNC) {
+        mode->flags |= DRM_MODE_FLAG_PVSYNC;
+    }
+    if (custom->flags & SDL_MODELINE_FLAG_NVSYNC) {
+        mode->flags |= DRM_MODE_FLAG_NVSYNC;
+    }
+    if (custom->flags & SDL_MODELINE_FLAG_INTERLACE) {
+        mode->flags |= DRM_MODE_FLAG_INTERLACE;
+    }
+    if (custom->flags & SDL_MODELINE_FLAG_DBLSCAN) {
+        mode->flags |= DRM_MODE_FLAG_DBLSCAN;
+    }
+    if (custom->flags & SDL_MODELINE_FLAG_CSYNC) {
+        mode->flags |= DRM_MODE_FLAG_CSYNC;
+    }
+    mode->hskew = 0;
+    mode->vscan = 0;
+
+    return mode;
+}
