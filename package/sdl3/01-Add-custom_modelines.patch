+static XRRModeInfo *X11_CreateModeFromCustom(const SDL_CustomDisplayMode *custom)
+{
+    XRRModeInfo *mode = SDL_calloc(1, sizeof(*mode));
+    if (!mode) {
+        return NULL;
+    }
+
+    mode->name = SDL_strdup(custom->name);
+    mode->nameLength = SDL_strlen(custom->name);
+
+    mode->width  = custom->hdisplay;
+    mode->height = custom->vdisplay;
+
+    mode->dotClock = (long)custom->pixel_clock_khz * 1000;
+
+    mode->hSyncStart = custom->hsync_start;
+    mode->hSyncEnd   = custom->hsync_end;
+    mode->hTotal     = custom->htotal;
+
+    mode->vSyncStart = custom->vsync_start;
+    mode->vSyncEnd   = custom->vsync_end;
+    mode->vTotal     = custom->vtotal;
+
+    mode->modeFlags = X11_ModeFlagsFromSDL(custom->flags);
+
+    return mode;
+}
